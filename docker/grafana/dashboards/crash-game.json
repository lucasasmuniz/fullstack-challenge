{
  "uid": "crash-game-overview",
  "title": "Crash Game — Overview",
  "tags": ["crash-game", "b4"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RTP (1h) — payouts / wagers",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 4 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(crash_game_payouts_cents_total[1h])) / clamp_min(sum(increase(crash_game_wagers_cents_total[1h])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Rodadas (total)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(crash_game_rounds_total)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Apostas por minuto",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(crash_game_bets_total[1m])) * 60",
          "legendFormat": "bets/min"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Volume apostado vs pago (centavos/min)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(crash_game_wagers_cents_total[1m])) * 60",
          "legendFormat": "wagered"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(crash_game_payouts_cents_total[1m])) * 60",
          "legendFormat": "paid"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Crash point (×100) — p50 / p90",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(crash_game_crash_point_x100_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.9, sum(rate(crash_game_crash_point_x100_bucket[5m])) by (le))",
          "legendFormat": "p90"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latência de emissão WebSocket (ms) — p95",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(crash_game_ws_emit_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Movimentos da carteira por motivo (/min)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(wallet_movements_total[5m])) by (reason) * 60",
          "legendFormat": "{{reason}}"
        }
      ]
    }
  ]
}
