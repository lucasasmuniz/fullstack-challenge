PORT=4001
DATABASE_URL=postgresql://admin:admin@postgres:5432/games

# Auth — Keycloak (OIDC / JWT)
KEYCLOAK_ISSUER=http://localhost:8080/realms/crash-game
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/crash-game/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=crash-game-client

# Messaging — AWS SQS via LocalStack
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_INBOX_QUEUE_URL=http://localstack:4566/000000000000/game-inbox
SQS_OUTBOUND_QUEUE_URL=http://localstack:4566/000000000000/wallet-inbox

# Cache / realtime
VALKEY_URL=redis://valkey:6379
