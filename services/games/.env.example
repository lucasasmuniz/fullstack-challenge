# Game Service — variáveis de ambiente.
#
# NÃO é necessário para `bun run docker:up`: o docker-compose injeta as envs (com hosts da rede
# Docker). Este arquivo é para rodar o serviço LOCALMENTE (fora do Docker) — os hosts apontam para
# `localhost` (a infra do compose expõe as portas no host). Copie para `.env` e ajuste se preciso:
#   cp services/games/.env.example services/games/.env
#
# Quase tudo tem default no schema (zod); as únicas obrigatórias sem default são as URLs (DATABASE_URL,
# KEYCLOAK_*, SQS_*, VALKEY_URL). Os valores abaixo são os defaults de desenvolvimento.

PORT=4001
DATABASE_URL=postgresql://admin:admin@localhost:5432/games

# Auth — Keycloak (OIDC / JWT). ISSUER deve bater com o `iss` do token emitido.
KEYCLOAK_ISSUER=http://localhost:8080/realms/crash-game
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/crash-game/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=crash-game-client

# Messaging — AWS SQS via LocalStack (credenciais fake do LocalStack).
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_INBOX_QUEUE_URL=http://localhost:4566/000000000000/game-inbox
SQS_OUTBOUND_QUEUE_URL=http://localhost:4566/000000000000/wallet-inbox

# Relay/consumer SQS (tuning).
MESSAGING_ENABLED=true
OUTBOX_RELAY_INTERVAL_MS=1000
OUTBOX_RELAY_BATCH_SIZE=20
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=10
SQS_VISIBILITY_TIMEOUT_SECONDS=30

# Cache / realtime.
VALKEY_URL=redis://localhost:6379
# Origem permitida no CORS do handshake WS. `*` é seguro aqui (auth é Bearer, não cookie).
WS_CORS_ORIGIN=*

# Limites de aposta (README: mín. 1,00 / máx. 1.000,00).
BET_MIN_CENTS=100
BET_MAX_CENTS=100000

# Engine / curva — timings configuráveis (janela de apostas etc.).
CRASH_GROWTH_RATE=0.06
BETTING_WINDOW_MS=8000
TICK_INTERVAL_MS=250
INTER_ROUND_DELAY_MS=3000

# Cadeia de seeds (provably fair).
SEED_CHAIN_LENGTH=100000
SEED_CHAIN_ROTATE_THRESHOLD=1000
SEED_BUFFER_SIZE=50
SEED_BUFFER_LOW_WATERMARK=10

# Provably fair (house edge / teto). divisor=101 → ~1% de house edge.
PROVABLY_FAIR_INSTANT_BUST_DIVISOR=101
PROVABLY_FAIR_MAX_CRASH_X100=1000000

# TEST-ONLY: força o crash num ponto fixo (×100) para e2e determinístico. NÃO definir em produção
# (quebra o provably fair). Usado só pelo docker-compose.e2e.yml.
# GAME_FIXED_CRASH_X100=200

# Leaderboard (cache Valkey).
LEADERBOARD_CACHE_TTL_MS=5000

# Observabilidade (OpenTelemetry / Prometheus).
OTEL_ENABLED=true
METRICS_PORT=9464

# Scheduler (lease do líder). SCHEDULER_ENABLED=false desliga a engine nesta instância.
SCHEDULER_LEASE_TTL_MS=10000
SCHEDULER_ENABLED=true

# Beacon de entropia pública (provably fair anti-pré-computação — drand).
# Offline/CI: o serviço cai para CSPRNG (loga WARN) e sobe normalmente.
BEACON_ENABLED=true
BEACON_BASE_URL=https://api.drand.sh
BEACON_CHAIN_HASH=52db9ba70e0cc0f6eaf7803dd07447a1f5477735fd3f661792ba94600c84e971
BEACON_ROUND_LEAD=2
BEACON_TIMEOUT_MS=3000
BEACON_POLL_MAX_MS=20000
