PORT=4001
DATABASE_URL=postgresql://admin:admin@postgres:5432/games

# Auth — Keycloak (OIDC / JWT)
KEYCLOAK_ISSUER=http://localhost:8080/realms/crash-game
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/crash-game/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=crash-game-client

# Messaging — AWS SQS via LocalStack
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_INBOX_QUEUE_URL=http://localstack:4566/000000000000/game-inbox
SQS_OUTBOUND_QUEUE_URL=http://localstack:4566/000000000000/wallet-inbox

# Cache / realtime
VALKEY_URL=redis://valkey:6379

# Engine / curva (Etapa 4) — timings configuráveis (nada hardcoded)
CRASH_GROWTH_RATE=0.06
BETTING_WINDOW_MS=8000
TICK_INTERVAL_MS=250
INTER_ROUND_DELAY_MS=3000

# Cadeia de seeds (provably fair)
SEED_CHAIN_LENGTH=100000
SEED_CHAIN_ROTATE_THRESHOLD=1000
SEED_BUFFER_SIZE=50
SEED_BUFFER_LOW_WATERMARK=10

# Provably fair (house edge / teto)
PROVABLY_FAIR_INSTANT_BUST_DIVISOR=101
PROVABLY_FAIR_MAX_CRASH_X100=1000000

# Scheduler (lease do líder)
SCHEDULER_LEASE_TTL_MS=10000
SCHEDULER_ENABLED=true

# Beacon de entropia pública (provably fair anti-pré-computação — drand; ADR 0017)
# Offline/CI: o serviço cai para CSPRNG (loga WARN) e sobe normalmente.
BEACON_ENABLED=true
BEACON_BASE_URL=https://api.drand.sh
BEACON_CHAIN_HASH=52db9ba70e0cc0f6eaf7803dd07447a1f5477735fd3f661792ba94600c84e971
BEACON_ROUND_LEAD=2
BEACON_TIMEOUT_MS=3000
BEACON_POLL_MAX_MS=20000
