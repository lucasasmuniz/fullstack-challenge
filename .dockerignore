# Build context é a raiz do monorepo — enxugar o que não vai pras imagens dos serviços.
**/node_modules
**/dist
**/coverage
**/*.log

.git
.gitignore
docs
# O frontend não vai pras imagens dos serviços, mas o manifesto é membro do workspace e o
# --frozen-lockfile exige todos os package.json presentes (o código fica de fora).
frontend/*
!frontend/package.json

# Env locais (os serviços recebem env via docker-compose `environment:`)
**/.env
**/.env.*
!**/.env.example
