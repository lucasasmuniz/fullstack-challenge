{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f",
    "lint": "eslint .",
    "typecheck": "bun run --filter '@crash-game/*' typecheck",
    "test": "bun test packages services/*/tests/unit",
    "test:e2e": "bun run --filter '@crash-game/*' test:e2e",
    "docker:rebuild": "docker compose up --build",
    "docker:e2e": "docker compose -f docker-compose.yml -f docker-compose.e2e.yml up --build -d --wait",
    "docker:e2e:down": "docker compose -f docker-compose.yml -f docker-compose.e2e.yml down",
    "seed:e2e": "bun run scripts/seed-e2e.ts",
    "test:system": "RUN_SYSTEM_E2E=1 bun test tests/system",
    "e2e:system": "bun run docker:e2e && bun run seed:e2e && bun run test:system"
  },
  "devDependencies": {
    "@crash-game/eslint-config": "workspace:*",
    "@crash-game/typescript-config": "workspace:*",
    "bun-types": "latest",
    "eslint": "^9.13.0",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.8.3"
  },
  "type": "module"
}
