{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f",
    "lint": "eslint .",
    "typecheck": "bun run --filter '@crash-game/*' typecheck",
    "test": "bun test"
  },
  "devDependencies": {
    "@crash-game/eslint-config": "workspace:*",
    "@crash-game/typescript-config": "workspace:*",
    "bun-types": "latest",
    "eslint": "^9.13.0",
    "typescript": "^5.8.3"
  }
}
